# Copy to .env and fill in values

# Database (local Docker Postgres)
DATABASE_URL="postgresql://hub:hub@localhost:5433/team_hub?schema=public"

# API
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development

# JWT secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=replace_me_with_random_64_byte_hex
JWT_REFRESH_SECRET=replace_me_with_random_64_byte_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Cloudinary (optional — leave blank for local file fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
